{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile for patients, doctors, and admins",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["patient", "doctor", "admin"] },
        "specialty": { "type": "string", "description": "Only for doctors" },
        "bio": { "type": "string" },
        "availability": { "type": "object", "description": "Weekly schedule for doctors" },
        "isApproved": { "type": "boolean", "description": "Admin approval for doctors" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "Appointment": {
      "title": "Appointment",
      "description": "Booking details between patient and doctor",
      "type": "object",
      "properties": {
        "patientId": { "type": "string" },
        "doctorId": { "type": "string" },
        "patientName": { "type": "string" },
        "doctorName": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["pending", "confirmed", "cancelled", "completed"] },
        "symptoms": { "type": "string" },
        "notes": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["patientId", "doctorId", "date", "status"]
    },
    "Prescription": {
      "title": "Prescription",
      "description": "Digital prescription issued by a doctor",
      "type": "object",
      "properties": {
        "appointmentId": { "type": "string" },
        "patientId": { "type": "string" },
        "doctorId": { "type": "string" },
        "diagnosis": { "type": "string" },
        "medications": { "type": "array", "items": { "type": "string" } },
        "instructions": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["appointmentId", "patientId", "doctorId", "diagnosis"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/appointments/{appointmentId}": {
      "schema": "Appointment",
      "description": "Appointment records"
    },
    "/prescriptions/{prescriptionId}": {
      "schema": "Prescription",
      "description": "Digital prescriptions"
    }
  }
}
